# Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================================
# DATABASE (Required)
# ============================================================================
# Get a free PostgreSQL database at https://neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL="postgresql://username:password@hostname/database?sslmode=require"

# ============================================================================
# AUTHENTICATION (Required)
# ============================================================================
# Generate a random secret for NextAuth
# Run: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ============================================================================
# AI FEATURES (Optional but recommended)
# ============================================================================
# Get your free API key at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-your-api-key-here"
OPENROUTER_MODEL="stepfun/step-3.5-flash:free"

# ============================================================================
# CRON / AUTOMATED REPORTS (Optional)
# ============================================================================
# Secret for securing cron job endpoints
CRON_SECRET="your-cron-secret-key"

# ============================================================================
# DEVELOPMENT ONLY (Remove in production)
# ============================================================================
# Secret for dev login bypass
DEV_LOGIN_SECRET="dev-mode-secret"
DEV_API_KEY="dev-api-key-for-testing"

# ============================================================================
# OPTIONAL FEATURES
# ============================================================================
# AWS S3 for file uploads (optional)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET=""
# AWS_REGION="us-east-1"

# Email service for notifications (optional)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# EMAIL_FROM="noreply@yourdomain.com"
