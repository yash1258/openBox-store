// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Seller {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hashed password with bcrypt
  name      String
  shopName  String   @default("My OpenBox Store")
  whatsapp  String   @default("")
  address   String?
  apiKeys   String   @default("[]") // JSON array of API keys
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  products  Product[]
  categories Category[]
  sessions  Session[]
  orders    Order[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  sellerId  String
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@index([token])
  @@index([sellerId])
}

model Product {
  id                String         @id @default(cuid())
  sellerId          String
  name              String
  description       String?
  category          String
  condition         String         @default("openbox") // openbox, used, like_new
  originalPrice     Float?
  sellingPrice      Float
  images            String         @default("[]") // JSON array of image URLs (legacy, migrating to ProductImage)
  status            String         @default("available") // available, sold, reserved
  stockQuantity     Int            @default(1)
  // Amazon integration
  amazonRating      Float?         // Amazon rating (e.g., 4.5)
  amazonReviewCount Int?           // Number of Amazon reviews
  amazonUrl         String?        // Link to Amazon product page
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  seller            Seller         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  cartItems         CartItem[]
  productImages     ProductImage[]
  reviews           Review[]
  successStories    SuccessStory[]
  stats             ProductStats?
  
  @@index([status])
  @@index([category])
  @@index([sellerId])
  @@index([sellerId, status])
  @@index([createdAt])
  @@index([name])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  order     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@index([productId])
}

model Category {
  id            String    @id @default(cuid())
  sellerId      String
  name          String
  slug          String
  icon          String?
  color         String?
  productCount  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  seller        Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, slug])
  @@index([sellerId])
}

model Cart {
  id        String     @id @default(cuid())
  sessionId String     @unique
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  @@index([sessionId])
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  quantity  Int     @default(1)
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
  
  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model Order {
  id              String        @id @default(cuid())
  customerName    String
  customerEmail   String
  customerPhone   String
  address         String
  items           OrderItem[]
  subtotal        Float         // Amount before discount
  discountAmount  Float         @default(0)
  totalAmount     Float         // Amount after discount
  status          String        @default("PENDING")
  paymentStatus   String        @default("PENDING")
  paymentMethod   String        @default("cod")
  couponId        String?
  coupon          Coupon?       @relation(fields: [couponId], references: [id])
  sellerId        String
  seller          Seller        @relation(fields: [sellerId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([status])
  @@index([sellerId])
  @@index([createdAt])
  @@index([couponId])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  @@index([orderId])
}

model Review {
  id           String   @id @default(cuid())
  productId    String
  customerName String
  rating       Int      // 1-5
  comment      String?
  createdAt    DateTime @default(now())
  
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@index([productId])
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String?
  discountType    String    @default("percentage") // percentage, fixed
  discountValue   Float     // Percentage (e.g., 10 for 10%) or fixed amount
  minOrderAmount  Float?    // Minimum cart value to apply coupon
  maxDiscount     Float?    // Maximum discount for percentage coupons
  usageLimit      Int?      // Total usage limit
  usageCount      Int       @default(0)
  startDate       DateTime?
  endDate         DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  orders          Order[]

  @@index([code])
  @@index([isActive])
  @@index([endDate])
}

model Settings {
  id        String   @id @default(cuid())
  shopName  String   @default("My OpenBox Store")
  whatsapp  String   @default("")
  address   String?
  apiKeys   String   @default("[]") // JSON array of API keys
  isDefault Boolean  @default(false) // Only one record should be true
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([isDefault])
}

model SuccessStory {
  id            String    @id @default(cuid())
  customerName  String
  location      String    // City/State
  customerPhoto String?   // Photo of customer with product (optional)
  productPhoto  String    // Photo of delivered product
  productId     String?   // Optional link to product
  product       Product?  @relation(fields: [productId], references: [id])
  productName   String    // Product they bought (for display)
  comment       String    // Their testimonial about the buying experience
  rating        Int       // 1-5 satisfaction rating
  orderId       String?   // Link to order for verification
  deliveredAt   DateTime  // When it was delivered
  featured      Boolean   @default(false) // Show on homepage/featured section
  published     Boolean   @default(false) // Admin approval required
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([published])
  @@index([featured])
  @@index([createdAt])
  @@index([productId])
}

// ============================================
// ANALYTICS MODELS - For AI Assistant
// ============================================

// Track user events (page views, cart actions, etc.)
model AnalyticsEvent {
  id          String   @id @default(cuid())
  type        String   // page_view, product_view, cart_add, cart_remove, search, checkout_start
  sessionId   String   // Anonymous session tracking
  productId   String?  // If product-related
  metadata    String   @default("{}") // JSON: { query, referrer, device, path, etc }
  createdAt   DateTime @default(now())
  
  @@index([type, createdAt])
  @@index([createdAt])
  @@index([sessionId])
  @@index([productId])
}

// Pre-computed daily reports (Excel replacement)
model DailyReport {
  id                    String   @id @default(cuid())
  date                  DateTime @unique
  
  // Traffic metrics
  pageViews             Int      @default(0)
  uniqueVisitors        Int      @default(0)
  productViews          Int      @default(0)
  avgSessionDuration    Int      @default(0) // seconds
  
  // Commerce metrics
  cartAdds              Int      @default(0)
  checkoutsStarted      Int      @default(0)
  orders                Int      @default(0)
  revenue               Float    @default(0)
  abandonedCarts        Int      @default(0)
  abandonedCartValue    Float    @default(0)
  avgOrderValue         Float    @default(0)
  
  // Conversion rates (percentages)
  viewToCartRate        Float    @default(0)
  cartToCheckoutRate    Float    @default(0)
  checkoutToOrderRate   Float    @default(0)
  overallConversionRate Float    @default(0)
  
  // Top performers
  topViewedProducts     String   @default("[]") // JSON: [{id, name, views}]
  topSoldProducts       String   @default("[]") // JSON: [{id, name, sales}]
  lowStockAlerts        String   @default("[]") // JSON: [{id, name, stock}]
  
  // AI-generated insights
  aiSummary             String?  // Natural language summary
  aiRecommendations     String   @default("[]") // JSON: [{type, message, priority}]
  
  // Status
  isAutoGenerated       Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@index([date])
  @@index([createdAt])
}

// Real-time product analytics (for live data)
model ProductStats {
  id                String   @id @default(cuid())
  productId         String   @unique
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  // Time-based counters
  viewsToday        Int      @default(0)
  viewsWeek         Int      @default(0)
  viewsMonth        Int      @default(0)
  
  // Conversion metrics
  cartAdds          Int      @default(0)
  orders            Int      @default(0)
  conversionRate    Float    @default(0) // percentage
  
  // Engagement
  avgTimeOnPage     Int      @default(0) // seconds
  lastViewedAt      DateTime?
  
  // Daily reset tracking
  lastResetDate     DateTime @default(now()) // To reset daily counters
  
  updatedAt         DateTime @updatedAt
  
  @@index([productId])
  @@index([viewsWeek])
  @@index([conversionRate])
}

// Cart events for abandonment tracking
model CartEvent {
  id          String   @id @default(cuid())
  sessionId   String
  eventType   String   // added, removed, abandoned, recovered
  productId   String?
  productName String?
  quantity    Int
  price       Float
  cartValue   Float    // Total cart value at time of event
  createdAt   DateTime @default(now())
  
  @@index([sessionId])
  @@index([eventType, createdAt])
  @@index([createdAt])
}
